<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pet Adoption</title>
    <link rel="stylesheet" href="/css/style.css" />
    {{#extraCss}}<link rel="stylesheet" href="{{extraCss}}" />{{/extraCss}}
    <link rel="icon" type="image/png" href="/images/favicon.png" />
</head>
<body>
<header>
    <div class="container">
        <a href="">Pet Adoption</a>
        <div class="header__actions">
            <form method="GET" action="/search">
                <input type="search" name="q" value="{{q}}" placeholder="Pesquise por raça" />
             <span class="header__user">Olá, {{user.name}}</span>

            </form>

            <div class="header__auth">
                <a class="btn btn--ghost" href="/adopt/pets">Pets para adoção</a>
                <a class="btn btn--ghost" href="/adopt"> Cadastrar animal para adoção</a>
                <button class="btn btn--ghost" type="button" data-theme-toggle aria-pressed="false">Modo escuro</button>

            </div>
        </div>
    </div>
</header>
