{{>partials/header}}
<nav>    
    <ul>
        <li class="{{#menu.all}}active{{/menu.all}}"><a href="/">Todos</a></li>
        <li class="{{#menu.dog}}active{{/menu.dog}}"><a href="/dogs">Cachorros</a></li>
        <li class="{{#menu.cat}}active{{/menu.cat}}"><a href="/cats">Gatos</a></li>
        <li class="{{#menu.fish}}active{{/menu.fish}}"><a href="/fishes">Peixes</a></li>
    </ul>
</nav>
{{#banner}}
  <section class="banner">
      <div class="banner__slides">
        <div class="banner__slide" style="background-image: url('images/{{background}}')"></div>
        <div class="banner__slide" style="background-image: url('/images/banner_dog.jpg')"></div>
        <div class="banner__slide" style="background-image: url('/images/banner_cat.jpg')"></div>
        <div class="banner__slide" style="background-image: url('/images/banner_fish.jpg')"></div>
      </div>
      <div class="banner__content">{{title}}</div>
    </section>
    <h2 class="section-title">Todos {{title}} disponíveis para adoção</h2>
{{/banner}}


  <section class="list-section">
    <div class="container list">
    {{#list}}
        <div class="item" role="button" tabindex="0"
             data-pet-name="{{name}}"
             data-pet-color="{{color}}"
             data-pet-sex="{{sex}}"
             data-pet-image="images/{{image}}"
             data-pet-story="{{story}}">
          <img src="images/{{image}}" class="item--image" alt="Foto de {{name}}" />
          <div class="item--name">{{name}} </div>
          <div class="item--color">Cor: {{color}} </div>
          <div class="item--genre">Gênero: {{sex}}</div>
        </div>
    {{/list}}
    </div>
  </section>

{{^list}}
  <div class="container no-list">
    <h2>Não há animais disponíveis nessa página</h2>
  </div>
{{/list}}

  <div class="modal" data-modal>
    <div class="modal__overlay" data-modal-close></div>
    <div class="modal__content" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <button class="modal__close" type="button" aria-label="Fechar" data-modal-close>×</button>
      <img class="modal__image" src="" alt="" />
      <h3 class="modal__title" id="modal-title"></h3>
      <p class="modal__info" data-modal-color></p>
      <p class="modal__info" data-modal-sex></p>
      <p class="modal__story" data-modal-story></p>
      <div class="modal__actions">
        <button class="btn btn--ghost" type="button" data-modal-close>Fechar</button>
        <button class="btn btn--solid modal__action" type="button" data-adopt>Quero adotar</button>
      </div>
    </div>
  </div>
{{>partials/footer}}
